{
  "name": "galactic-unicorn-web-sdk",
  "version": "1.0.0",
  "description": "Browser-based SDK for developing Lua scripts for the Galactic Unicorn handheld: it combines an emulator, an in-browser editor, and serial-style console output so you can iterate without reflashing hardware on every change.",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "build:fengari": "sh ./scripts/build-fengari.sh",
    "build:littlefs": "sh ./scripts/build-littlefs.sh",
    "build:data": "sh ./scripts/build-data.sh",
    "build:vendor": "npm run build:fengari && npm run build:littlefs && npm run build:data",
    "predev": "npm run build:vendor",
    "prebuild": "npm run build:vendor",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/florian-rieder/galactic-unicorn-web-sdk.git"
  },
  "keywords": [],
  "author": "",
  "license": "",
  "bugs": {
    "url": "https://github.com/florian-rieder/galactic-unicorn-web-sdk/issues"
  },
  "homepage": "https://github.com/florian-rieder/galactic-unicorn-web-sdk#readme",
  "dependencies": {
    "esptool-js": "^0.6.0",
    "fengari": "^0.1.5",
    "fflate": "^0.8.3",
    "file-saver": "^2.0.5",
    "monaco-editor": "^0.55.1",
    "sweetalert2": "^11.26.25"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "vite": "^8.0.13",
    "vite-plugin-monaco-editor": "^1.1.0"
  }
}
